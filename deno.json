{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "name": "@denex/localnet",
  "version": "0.1.0",
  "exports": {
    ".": "./src/mod.ts",
    "./sdk": "./src/sdk/mod.ts",
    "./cli": "./src/cli/mod.ts",
    "./types": "./src/types/mod.ts"
  },
  "tasks": {
    "dev": "deno run --watch --allow-all src/cli/mod.ts",
    "cli": "deno run --allow-all src/cli/mod.ts",
    "test": "deno test --allow-all",
    "test:unit": "deno test --allow-all test/unit/",
    "test:integration": "deno test --allow-all test/integration/",
    "check": "deno check src/mod.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "playwright:install": "deno run --allow-all npm:playwright install chromium"
  },
  "imports": {
    "@std/yaml": "jsr:@std/yaml@^1.0.0",
    "yaml": "npm:yaml@^2.7.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "zod": "npm:zod@^3.23.0",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.7",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0-rc.7",
    "@cliffy/table": "jsr:@cliffy/table@^1.0.0-rc.7",
    "hono": "jsr:@hono/hono@^4.6.0",
    "dockerode": "npm:dockerode@^4.0.0",
    "@types/dockerode": "npm:@types/dockerode@^3.3.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-unused-vars"]
    }
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": true
  },
  "nodeModulesDir": "auto"
}
